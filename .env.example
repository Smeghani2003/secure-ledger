# Copy this file to .env and fill in real values
# .env is gitignored — never commit real secrets

# --- Database ---
POSTGRES_USER=secureledger
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=secureledger
DATABASE_URL=postgresql+asyncpg://secureledger:changeme_local_only@db:5432/secureledger

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace_with_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Token-at-rest encryption (Fernet) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_with_fernet_key

# --- Plaid (sandbox) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=

# --- App ---
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
